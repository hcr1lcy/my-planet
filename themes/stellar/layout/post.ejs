<article class="post-full">
    <header class="post-header">
        <h1><%= page.title %></h1>
        <div class="post-meta">
            <span><%= date(page.date, 'YYYY-MM-DD HH:mm') %></span>
            <% if (page.updated && page.updated !== page.date) { %>
                <span>更新于 <%= date(page.updated, 'YYYY-MM-DD HH:mm') %></span>
            <% } %>
        </div>
        <% if (page.tags && page.tags.length) { %>
            <div class="post-tags">
                <% page.tags.forEach(function(tag) { %>
                    <a href="<%- url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
                <% }) %>
            </div>
        <% } %>
        <% if (page.categories && page.categories.length) { %>
            <div class="post-categories">
                <% page.categories.forEach(function(cat) { %>
                    <a href="<%- url_for(cat.path) %>" class="category"><%= cat.name %></a>
                <% }) %>
            </div>
        <% } %>
    </header>

    <div class="post-content">
        <%- page.content %>
    </div>

    <nav class="post-nav">
        <% if (page.prev) { %>
            <a href="<%- url_for(page.prev.path) %>" class="nav-prev">← <%= page.prev.title %></a>
        <% } %>
        <% if (page.next) { %>
            <a href="<%- url_for(page.next.path) %>" class="nav-next"><%= page.next.title %> →</a>
        <% } %>
    </nav>
</article>
